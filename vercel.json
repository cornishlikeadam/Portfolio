{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/mirror5000/confirmed", "destination": "/confirmed" },
    { "source": "/mirror5000/payment-pending", "destination": "/payment-pending" },
    { "source": "/mirror5000/trillion-unlocked", "destination": "/trillion-unlocked" },
    { "source": "/mirror5000", "destination": "/mirror5000" },
    { "source": "/mirror5000-test/confirmed", "destination": "/confirmed-test" },
    { "source": "/mirror5000-test/payment-pending", "destination": "/payment-pending" },
    { "source": "/mirror5000-test/trillion-unlocked", "destination": "/trillion-unlocked" },
    { "source": "/mirror5000-test", "destination": "/mirror5000-test" }
  ],
  "headers": [
    {
      "source": "/assets/seen-until-believed-sacred-tech-edition.pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"seen-until-believed-sacred-tech-edition.pdf\""
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
